rules_version = '2';

// ВАЖНО: В Firebase Storage каждый отдельный бакет (bucket) должен описываться своим корневым блоком match /b/{имя_бакета}/o. 
// Вложение бакетов друг в друга вызывает ошибку компиляции.

service firebase.storage {
  
  // 1. БАКЕТ: ailbee-books (Хранилище книг)
  // Пользователи могут читать книги. Загрузка идет ТОЛЬКО через бэкенд FastAPI (Cloud Run).
  match /b/ailbee-books/o {
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }

  // 2. БАКЕТ: ailbee-user-data (Пользовательские данные)
  // Жесткая изоляция: каждый студент видит и изменяет только файлы в папке со своим UID.
  match /b/ailbee-user-data/o {
    match /{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }

  // 3. БАКЕТ: ailbee-data-exports (Отчеты)
  // Студент может скачать только свой отчет, сгенерированный бэкендом.
  match /b/ailbee-data-exports/o {
    match /{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }
  }

  // 4. ДЕФОЛТНЫЙ БАКЕТ (Для стандартных загрузок из FlutterFlow)
  // Если FlutterFlow загружает аватарки в бакет по умолчанию.
  match /b/{bucket}/o {
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
